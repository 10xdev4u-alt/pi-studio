{
  "name": "pi-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based multi-agent UI for the pi coding harness",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.base.json --noEmit && npm run typecheck --workspaces --if-present",
    "dev:daemon": "npm run dev -w @pi-studio/daemon",
    "dev:browser": "npm run dev -w @pi-studio/browser",
    "dev": "concurrently -n daemon,browser -c blue,magenta \"npm:dev:daemon\" \"npm:dev:browser\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1"
  }
}
